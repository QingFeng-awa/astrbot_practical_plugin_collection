{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AstrBot Plugin Metadata",
  "description": "Astrbot Plugin Metadata Information",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "插件唯一识别名，应以 astrbot_plugin_ 前缀开头。",
      "pattern": "^astrbot_plugin_.+$"
    },
    "display_name": {
      "type": "string",
      "description": "插件显示名称，可以是方便阅读的名字。"
    },
    "desc": {
      "type": "string",
      "description": "插件描述。"
    },
    "description": {
      "type": "string",
      "description": "插件描述。\n@Deprecated 不受推荐的字段，应使用更简短的 desc。"
    },
    "short_desc": {
      "type": "string",
      "description": "一句话介绍你的插件。该字段将作为插件市场卡片上的短描述，它适合写成一句简短介绍。如果没有提供，卡片会回退显示 desc。"
    },
    "version": {
      "type": "string",
      "description": "插件版本号。"
    },
    "author": {
      "type": "string",
      "description": "作者名称。"
    },
    "repo": {
      "type": "string",
      "description": "插件的 GitHub 仓库链接。",
      "pattern": "^https://github\\.com/[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+(/)?$",
      "format": "uri"
    },
    "support_platforms": {
      "type": "array",
      "description": "插件支持的平台适配器。",
      "items": {
        "type": "string",
        "enum": [
          "aiocqhttp",
          "qq_official",
          "qq_official_webhook",
          "telegram",
          "wecom",
          "wecom_ai_bot",
          "lark",
          "dingtalk",
          "discord",
          "slack",
          "kook",
          "vocechat",
          "weixin_official_account",
          "weixin_oc",
          "satori",
          "misskey",
          "line",
          "matrix",
          "mattermost"
        ]
      }
    },
    "astrbot_version": {
      "type": "string",
      "description": "插件支持的 AstrBot 版本范围，遵循 PEP 440 规范。",
      "pattern": "^(>=|~=|<=)?[0-9]+(\\.[0-9]+){0,2}(-[a-zA-Z0-9]+)?$"
    }
  },
  "required": [
    "name",
    "version",
    "author"
  ],
  "oneOf": [
    {
      "required": [
        "desc"
      ],
      "description": "使用 desc 字段"
    },
    {
      "required": [
        "description"
      ],
      "description": "使用 description 字段"
    }
  ],
  "additionalProperties": false
}