{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": {
        "$ref": "#/definitions/configItem"
    },
    "definitions": {
        "configItem": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "配置项的类型。\n当类型为 text 时，将会可视化为一个更大的可拖拽宽高的 textarea 组件，以适应大文本。",
                    "enum": [
                        "string",
                        "text",
                        "int",
                        "float",
                        "bool",
                        "object",
                        "list",
                        "dict",
                        "template_list",
                        "file"
                    ]
                },
                "description": {
                    "type": "string",
                    "description": "配置项的显示名称。"
                },
                "hint": {
                    "type": "string",
                    "description": "配置项的描述信息，显示在显示名称下方。"
                },
                "obvious_hint": {
                    "type": "boolean",
                    "description": "配置项的描述是否要醒目显示（其实就是描述开始前添加 Emoji 感叹号）。",
                    "default": false
                },
                "invisible": {
                    "type": "boolean",
                    "description": "配置项是否隐藏。\n如果设置为 true，则不会在 WebUI 上显示。\n用户仍可在数据目录中修改选项值。",
                    "default": false
                },
                "options": {
                    "type": "array",
                    "description": "配置指定的选项列表。\n若配置此项，将显示一个下拉菜单并替代掉原先的输入框。",
                    "items": {
                        "type": "string"
                    }
                },
                "editor_mode": {
                    "type": "boolean",
                    "description": "[Added in v3.5.10]\n是否启用代码编辑器模式。",
                    "default": false
                },
                "editor_language": {
                    "type": "string",
                    "description": "代码编辑器的代码语言。",
                    "default": "json"
                },
                "editor_theme": {
                    "type": "string",
                    "description": "代码编辑器的主题。",
                    "enum": [
                        "vs-light",
                        "vs-dark"
                    ],
                    "default": "vs-light"
                },
                "_special": {
                    "type": "string",
                    "description": "[Added in v4.0.0]\n用于调用 AstrBot 提供的可视化提供商选取、人格选取、知识库选取等功能。",
                    "enum": [
                        "select_provider",
                        "select_provider_tts",
                        "select_provider_stt",
                        "select_persona"
                    ]
                },
                "default": {
                    "description": "配置项的默认值。\n如果用户没有配置，将使用默认值。\nint 是 0，float 是 0.0，bool 是 False，string 是 \"\"，object 是 {}，list 是 []。"
                },
                "items": {
                    "type": "object",
                    "description": "如果配置的类型是 object，需要添加 items 字段。\nitems 的内容是这个配置项的子 Schema。\n理论上可以无限嵌套，但是不建议过多嵌套。"
                },
                "file_types": {
                    "type": "array",
                    "description": "允许上传的文件类型列表，如 [\"pdf\", \"docx\"]。",
                    "items": {
                        "type": "string"
                    }
                },
                "templates": {
                    "type": "object",
                    "description": "模板定义。",
                    "additionalProperties": {
                        "$ref": "#/definitions/templateDefinition"
                    }
                },
                "template_schema": {
                    "type": "object",
                    "description": "模板 schema，当设置之后，用户可以透过 WebUI 快速编辑模板。",
                    "additionalProperties": {
                        "$ref": "#/definitions/templateItem"
                    }
                },
                "slider": {
                    "type": "object",
                    "description": "滑块配置。\n若配置此项，将配置项输入框旁显示一个滑块控件。",
                    "properties": {
                        "min": {
                            "type": "number",
                            "description": "最小值"
                        },
                        "max": {
                            "type": "number",
                            "description": "最大值"
                        },
                        "step": {
                            "type": "number",
                            "description": "步长"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "required": [
                "type"
            ],
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "object"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "items"
                        ],
                        "properties": {
                            "items": {
                                "type": "object",
                                "additionalProperties": {
                                    "$ref": "#/definitions/configItem"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "file"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "file_types": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "dict"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "items": {
                                "type": "object",
                                "additionalProperties": {
                                    "$ref": "#/definitions/configItem"
                                }
                            },
                            "template_schema": {
                                "type": "object",
                                "additionalProperties": {
                                    "$ref": "#/definitions/templateItem"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "template_list"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "templates"
                        ],
                        "properties": {
                            "templates": {
                                "type": "object",
                                "additionalProperties": {
                                    "$ref": "#/definitions/templateDefinition"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "int",
                                    "float"
                                ]
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "slider": {
                                "type": "object",
                                "properties": {
                                    "min": {
                                        "type": "number"
                                    },
                                    "max": {
                                        "type": "number"
                                    },
                                    "step": {
                                        "type": "number"
                                    }
                                },
                                "additionalProperties": false
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "string",
                                    "text"
                                ]
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "default": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "int"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "default": {
                                "type": "integer"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "float"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "default": {
                                "type": "number"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "bool"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "default": {
                                "type": "boolean"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "object",
                                    "dict"
                                ]
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "default": {
                                "type": "object"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "list",
                                    "file",
                                    "template_list"
                                ]
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "default": {
                                "type": "array"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "not": {
                                    "enum": [
                                        "object",
                                        "dict"
                                    ]
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "items": {
                                "not": {}
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "not": {
                                    "const": "dict"
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "template_schema": {
                                "not": {}
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "not": {
                                    "const": "template_list"
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "templates": {
                                "not": {}
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "not": {
                                    "enum": [
                                        "int",
                                        "float"
                                    ]
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "slider": {
                                "not": {}
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "not": {
                                    "const": "file"
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "file_types": {
                                "not": {}
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "not": {
                                    "enum": [
                                        "string",
                                        "text"
                                    ]
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "render_type": {
                                "not": {}
                            }
                        }
                    }
                }
            ]
        },
        "templateItem": {
            "description": "模板项定义，用于 dict 类型的 template_schema。",
            "allOf": [
                {
                    "$ref": "#/definitions/configItem"
                },
                {
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "模板项的显示名称。"
                        }
                    }
                }
            ]
        },
        "templateDefinition": {
            "type": "object",
            "description": "模板定义，用于 template_list 类型的 templates 字段。",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "模板的显示名称。"
                },
                "hint": {
                    "type": "string",
                    "description": "模板的提示信息。"
                },
                "items": {
                    "type": "object",
                    "description": "模板的子配置项 Schema。",
                    "additionalProperties": {
                        "$ref": "#/definitions/configItem"
                    }
                }
            },
            "required": [
                "name",
                "items"
            ]
        }
    }
}